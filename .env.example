# Обязательные переменные (скопируйте этот файл в .env и заполните)

# ── Приложение ────────────────────────────────────────────────
# API-токен для внешних CI/CD систем (GitHub Actions, GitLab CI и т.д.)
SECRET_TOKEN=change-me-secret-token

# Порт на хост-машине
PORT=8080

# Таймаут выполнения скрипта в секундах
SCRIPT_TIMEOUT=600

# ── Веб-интерфейс ─────────────────────────────────────────────
UI_USERNAME=admin
UI_PASSWORD=change-me-ui-password

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=deploy
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=deploy_db
